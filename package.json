{
  "name": "job-tracker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI-powered job search tracker with CLI, API, and agent integration",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint 'src/**/*.ts' 'cli/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' 'cli/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts' 'cli/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'cli/**/*.ts'",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "cli": "tsx cli/index.ts",
    "typecheck": "tsc --noEmit && echo 'Type check passed'",
    "prepare": "husky"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.9.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "commander": "13.1.0",
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "helmet": "8.2.0",
    "morgan": "1.11.0",
    "pg": "8.22.0",
    "swagger-ui-express": "5.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/morgan": "1.9.10",
    "@types/node": "26.0.1",
    "@types/pg": "8.20.0",
    "@types/supertest": "7.2.0",
    "@types/swagger-ui-express": "4.1.8",
    "@vitest/coverage-v8": "3.2.6",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "husky": "9.1.7",
    "prisma": "7.8.0",
    "supertest": "7.2.2",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.62.0",
    "vitest": "3.2.6"
  }
}

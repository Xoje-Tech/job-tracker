// Prisma schema for Job Tracker — SQLite (local development)
// AI-powered job search management system
//
// This is a SQLite-compatible version of schema.postgres.prisma.
// Enums are replaced with String fields with @default() matching the
// first enum value. Validation should happen at the application layer.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

/// Represents a job listing found from any source (manual entry, scraper, API)
model Job {
  id             String   @id @default(cuid())
  title          String
  company        String
  location       String?
  remote         String   @default("ONSITE")
  salaryMin      Int?
  salaryMax      Int?
  salaryCurrency String   @default("EUR")
  url            String?  @unique
  description    String
  source         String   @default("MANUAL")
  sourceId       String? // External ID from the source platform
  status         String   @default("SAVED")
  priority       String   @default("MEDIUM")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  appliedAt      DateTime?
  archivedAt     DateTime?

  // Relations
  companyRef     Company?      @relation(fields: [companyRefId], references: [id])
  companyRefId   String?
  applications   Application[]
  tags           JobTag[]
  documents      Document[]
  aiChats        AIChat[]
  reminders      Reminder[]

  @@index([status])
  @@index([company])
  @@index([createdAt])
  @@index([source, sourceId])
}

/// A company can have multiple job listings
model Company {
  id          String   @id @default(cuid())
  name        String   @unique
  website     String?
  industry    String?
  size        String   @default("UNKNOWN")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  jobs        Job[]
}

/// Job application tracking — the core workflow entity
model Application {
  id              String   @id @default(cuid())
  jobId           String
  status          String   @default("DRAFT")
  coverLetter     String?
  cvVersion       String?
  expectedSalary  Int?
  availabilityDate DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  job             Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  events          ApplicationEvent[]
  interviews      Interview[]

  @@index([status])
  @@index([jobId])
}

/// Timeline events for an application (status changes, notes, actions)
model ApplicationEvent {
  id            String   @id @default(cuid())
  applicationId String
  type          String   @default("STATUS_CHANGE")
  oldValue      String?
  newValue      String?
  note          String?
  createdAt     DateTime @default(now())

  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([createdAt])
}

/// Interview scheduling and tracking
model Interview {
  id            String   @id @default(cuid())
  applicationId String
  round         Int      @default(1)
  type          String   @default("VIDEO")
  scheduledAt   DateTime
  duration      Int      @default(60) // minutes
  interviewer   String?
  notes         String?
  feedback      String?
  result        String   @default("PENDING")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([scheduledAt])
}

/// Documents associated with jobs/applications (CVs, cover letters, contracts)
model Document {
  id        String   @id @default(cuid())
  jobId     String?
  type      String   @default("CV")
  name      String
  path      String   // Local file path or storage URL
  mimeType  String?
  size      Int?     // bytes
  createdAt DateTime @default(now())

  job       Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)
}

/// Tags for categorizing jobs
model Tag {
  id    String  @id @default(cuid())
  name  String  @unique
  color String?
  jobs  JobTag[]
}

/// Many-to-many join for Jobs <-> Tags
model JobTag {
  jobId String
  tagId String
  job   Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([jobId, tagId])
}

/// AI conversation history related to a job search
model AIChat {
  id        String   @id @default(cuid())
  jobId     String?
  role      String   @default("USER")
  content   String
  metadata  Json?    // Store AI model used, token count, etc.
  createdAt DateTime @default(now())

  job       Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([jobId])
}

/// Reminders for follow-ups, deadlines, etc.
model Reminder {
  id        String   @id @default(cuid())
  jobId     String
  type      String   @default("FOLLOW_UP")
  dueDate   DateTime
  message   String
  done      Boolean  @default(false)
  createdAt DateTime @default(now())
  doneAt    DateTime?

  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([dueDate])
  @@index([done])
}

/// Saved job search queries for recurring searches
model SearchQuery {
  id          String   @id @default(cuid())
  name        String
  query       String   // Search string
  filters     Json?    // Structured filters
  isActive    Boolean  @default(true)
  lastRunAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
